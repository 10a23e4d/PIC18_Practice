#define DIO_52 PIN_D4
#define DIO_55 PIN_D1
#define DIO_58 PIN_D0
#define DIO_59 PIN_E7

// --- MT25QL01GBBB コマンド定義 ---
#define CMD_READ_ID       0x9F
#define CMD_WRITE_ENABLE  0x06
#define CMD_READ_STATUS   0x05
#define CMD_READ_DATA     0x03
#define CMD_PAGE_PROGRAM  0x02 // 3-byte address page program
#define CMD_SECTOR_ERASE  0x20 // 4KB Subsector Erase (3-byte address)
#define CMD_BULK_ERASE    0xC7

// ★★★ 動作モード切り替え ★★★
// 0: ID読み取り (通常)
// 1: GPIOテスト (テスター用)
// 2: SPI連続送信 (オシロ用)
// 3: Flash書き込み/読み出しテスト (NEW!)
#define OPERATION_MODE 3

// --- 関数プロトタイプ宣言 ---
void flash_write_enable();
void flash_wait_busy();
void flash_sector_erase(int32 addr);
void flash_page_program(int32 addr, int8 *data, int16 len);
void flash_read_data(int32 addr, int8 *buffer, int16 len);

// --- メイン関数 ---
void main() {
   int8 manufacturer_id, memory_type, memory_capacity;
   int8 write_buf[10] = {0xAA, 0xBB, 0xCC, 0xDD, 0xEE, 1, 2, 3, 4, 5};
   int8 read_buf[10];
   int i;

      setup_adc_ports(NO_ANALOGS);

   // CS初期化
   output_high(SPI1_CS);

   fprintf(PORT1, "\r\n=== System Started ===\r\n");
   delay_ms(100);

#if OPERATION_MODE == 3
   // --- モード3: Flash R/W テスト ---
   fprintf(PORT1, "Mode 3: Flash Read/Write Test Start.\r\n");

   while(TRUE) {
      // 1. まずID確認
      output_high(SPI1_CS);
      spi_xfer(SPI1, CMD_READ_ID);
      manufacturer_id = spi_xfer(SPI1, 0x00);
      spi_xfer(SPI1, 0x00); spi_xfer(SPI1, 0x00); // 残りは読み飛ばし
      output_high(SPI1_CS);

      if(manufacturer_id != 0x20) {
         fprintf(PORT1, "Error: Flash ID mismatch (0x%X). Check connection.\r\n", manufacturer_id);
         delay_ms(1000);
         continue;
      }

      fprintf(PORT1, "1. Flash Found. Test Addr: 0x001000\r\n");

      // 2. セクタ消去 (4KB Erase)
      // 書き込みの前には必ず消去が必要です。
      fprintf(PORT1, "2. Erasing Sector... ");
      flash_write_enable();
      flash_sector_erase(0x001000);
      flash_wait_busy(); // 消去完了待ち
      fprintf(PORT1, "Done.\r\n");

      // 3. 書き込み (Page Program)
      fprintf(PORT1, "3. Writing Data {0xAA, 0xBB...}... ");
      flash_write_enable();
      flash_page_program(0x001000, write_buf, 10);
      flash_wait_busy(); // 書き込み完了待ち
      fprintf(PORT1, "Done.\r\n");

      // 4. 読み出し検証
      fprintf(PORT1, "4. Reading Data... ");
      // バッファクリア
      for(i=0; i<10; i++) read_buf[i] = 0;

      flash_read_data(0x001000, read_buf, 10);

      // 比較
      int match = 1;
      for(i=0; i<10; i++) {
         if(read_buf[i] != write_buf[i]) match = 0;
      }

      if(match) {
         fprintf(PORT1, "[SUCCESS] Data Matches!\r\n");
         for(i=0; i<10; i++) fprintf(PORT1, "%02X ", read_buf[i]);
         fprintf(PORT1, "\r\n");
      } else {
         fprintf(PORT1, "[FAIL] Data Mismatch.\r\n");
         fprintf(PORT1, "Read: ");
         for(i=0; i<10; i++) fprintf(PORT1, "%02X ", read_buf[i]);
         fprintf(PORT1, "\r\n");
      }

      fprintf(PORT1, "--- Test Finished (Wait 5s) ---\r\n");
      delay_ms(5000);
   }

#elif OPERATION_MODE == 1
   // --- モード1: GPIOテスト ---
   // ... (以前と同じコード) ...
   fprintf(PORT1, "Mode 1: GPIO Toggle Test.\r\n");
   while(TRUE) {
      output_low(SPI1_CS); delay_ms(2000);
      output_high(SPI1_CS); delay_ms(2000);
      output_low(PIN_A3); delay_ms(2000);
      output_high(PIN_A3); delay_ms(2000);
      output_low(PIN_A1); delay_ms(2000);
      output_high(PIN_A1); delay_ms(2000);
   }

#elif OPERATION_MODE == 2
   // --- モード2: SPI連続送信 ---
   // ... (以前と同じコード) ...
   output_low(SPI1_CS);
   while(TRUE) {
      spi_xfer(SPI1, 0x55);
   }

#else
   // --- モード0: ID読み取りのみ ---
   fprintf(PORT1, "Mode 0: Read ID Only.\r\n");
   while(TRUE) {
      output_low(SPI1_CS);
      spi_xfer(SPI1, CMD_READ_ID);
      manufacturer_id = spi_xfer(SPI1, 0x00);
      memory_type = spi_xfer(SPI1, 0x00);
      memory_capacity = spi_xfer(SPI1, 0x00);
      output_high(SPI1_CS);
      fprintf(PORT1, "ID: %02X %02X %02X\r\n", manufacturer_id, memory_type, memory_capacity);
      delay_ms(1000);
   }
#endif
}

// --- Flash操作関数群 ---

// 書き込み許可 (Write Enable)
void flash_write_enable() {
   output_low(SPI1_CS);
   spi_xfer(SPI1, CMD_WRITE_ENABLE); // 0x06
   output_high(SPI1_CS);
}

// ビジー待機 (Status RegisterのWIPビット監視)
void flash_wait_busy() {
   int8 status;
   do {
      output_low(SPI1_CS);
      spi_xfer(SPI1, CMD_READ_STATUS); // 0x05
      status = spi_xfer(SPI1, 0x00);
      output_high(SPI1_CS);
      // Bit 0 が WIP (Write In Progress)
   } while (status & 0x01);
}

// セクタ消去 (4KB Subsector Erase)
void flash_sector_erase(int32 addr) {
   output_low(SPI1_CS);
   spi_xfer(SPI1, CMD_SECTOR_ERASE); // 0x20

   // 3バイトアドレス送信 (MSB First)
   spi_xfer(SPI1, (addr >> 16) & 0xFF);
   spi_xfer(SPI1, (addr >> 8) & 0xFF);
   spi_xfer(SPI1, addr & 0xFF);

   output_high(SPI1_CS);
}

// ページプログラム (データ書き込み)
void flash_page_program(int32 addr, int8 *data, int16 len) {
   int16 i;

   output_low(SPI1_CS);
   spi_xfer(SPI1, CMD_PAGE_PROGRAM); // 0x02

   // 3バイトアドレス送信
   spi_xfer(SPI1, (addr >> 16) & 0xFF);
   spi_xfer(SPI1, (addr >> 8) & 0xFF);
   spi_xfer(SPI1, addr & 0xFF);

   // データ送信
   for(i=0; i<len; i++) {
      spi_xfer(SPI1, data[i]);
   }

   output_high(SPI1_CS);
}

// データ読み出し
void flash_read_data(int32 addr, int8 *buffer, int16 len) {
   int16 i;

   output_low(SPI1_CS);
   spi_xfer(SPI1, CMD_READ_DATA); // 0x03

   // 3バイトアドレス送信
   spi_xfer(SPI1, (addr >> 16) & 0xFF);
   spi_xfer(SPI1, (addr >> 8) & 0xFF);
   spi_xfer(SPI1, addr & 0xFF);

   // データ受信
   for(i=0; i<len; i++) {
      buffer[i] = spi_xfer(SPI1, 0x00);
   }

   output_high(SPI1_CS);
}
