#define SPI1_CS PIN_A2
#use spi (MASTER, CLK = PIN_A3, DI = PIN_A0, DO = PIN_A1,BAUD=1000000, MODE=0, BITS=8, STREAM=SPI1)


#define DIO_3 PIN_G0
