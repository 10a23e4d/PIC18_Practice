#include <18F67J94.h>
#include "LED1.h"
#device ADC=10


// --- UART/PPS設定 ---
// ボードの「U1TX」は物理的に PIN_C6 に繋がっているため、ここを変更します
#pin_select U1TX = PIN_C6
#pin_select U1RX = PIN_C7

// xmit/rcv も物理ピン C6/C7 に変更
#use rs232(baud=9600, parity=N, xmit=PIN_C6, rcv=PIN_C7, bits=8, stream=PORT1)

// --- DIO設定 ---
#define DIO_3 PIN_G0

void main()
{
    // ピン出力設定
    output_drive(DIO_3);
    output_drive(PIN_C6); // TXピン(C6)を出力に設定

    delay_ms(100);

    // 開始メッセージ
    fprintf(PORT1, "Start\r\n");

    while(true)
    {
        // "U" (0x55) は 01010101... となるので波形確認に最適です
        fprintf(PORT1, "U");

        // Lチカ (8MHz設定でdelay_ms(500)なら0.5秒間隔になるはずです)
        output_toggle(DIO_3);

        delay_ms(500);
    }
}