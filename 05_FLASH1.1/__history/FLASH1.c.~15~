// セクタ消去 (4KB Subsector Erase)
void flash_sector_erase(int32 addr) {
   output_low(SPI2_CS);
   spi_xfer(SPI2, CMD_SECTOR_ERASE); // 0x20

   // 3バイトアドレス送信 (MSB First)
   spi_xfer(SPI2, (addr >> 16) & 0xFF);
   spi_xfer(SPI2, (addr >> 8) & 0xFF);
   spi_xfer(SPI2, addr & 0xFF);

   output_high(SPI2_CS);
}

