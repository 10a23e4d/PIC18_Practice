....................       
....................       delay_us(2);
....................       
....................       output_low(FLASH128M_CS);
....................       ///////////////////////////////////////////////////////////////////
....................       spi_xfer(FLASH128M,SUBSECTOR_4KB_ERASE_4BYTE);
....................       
....................       spi_xfer(FLASH128M,address[0]);   
....................       spi_xfer(FLASH128M,address[1]);    
....................       spi_xfer(FLASH128M,address[2]);    
....................       //////////////////////////////////////////////////////////////////
....................       
