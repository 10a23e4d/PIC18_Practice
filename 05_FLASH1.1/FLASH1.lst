....................       address[1]  = (unsigned int8)((subsector_address>>8) & 0xff);    // 0x 00 00 _ _ 00
....................       address[2]  = (unsigned int8)((subsector_address) & 0xff);       // 0x 00 00 00 _ _
....................       
