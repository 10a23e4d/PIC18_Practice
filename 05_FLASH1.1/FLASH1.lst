.................... 
.................... // NOIHSгҒҢиЎЁзӨәгҒ•гӮҢгӮӢгӮӮгҒ® (жӯЈеёёпјү
.................... void main()
.................... {
....................    // гҒ“гҒ“гҒ«жӣёгҒҚиҫјгҒҝгҒҹгҒ„ж–Үеӯ—еҲ—гӮ’жҢҮе®ҡгҒ—гҒҰгҒҸгҒ гҒ•гҒ„пјҲ5ж–Үеӯ—зЁӢеәҰжҺЁеҘЁпјү
....................    char write_str[] = "NOIHS";
.................... 
....................    // е®ҡзҫ©гҒ—гҒҹж–Үеӯ—еҲ—гӮ’иЎЁзӨә
....................    fprintf(PORT1, "String to Write: %s\r\n", write_str);
.................... 
....................    // ж–Үеӯ—еҲ—гҒ®й•·гҒ•гӮ’иЁҲз®—пјҲзөӮз«ҜгҒ®гғҢгғ«ж–Үеӯ—еҲҶгӮ’йҷӨгҒҸпјү
....................    int8 data_len = sizeof(write_str) - 1;
.................... 
....................    // иӘӯгҒҝеҮәгҒ—гҒҹгғҮгғјгӮҝгӮ’ж јзҙҚгҒҷгӮӢгғҗгғғгғ•гӮЎпјҲе°‘гҒ—еӨ§гҒҚгӮҒгҒ«зўәдҝқпјү
....................    int8 read_buf[20];
....................    int8 i;
.................... 
....................    fprintf(PORT1, "==Program Start==\r\n");
.................... 
....................    fprintf(PORT1, "Flash Setting Starting...\r\n");
....................    flash_setting();
....................    fprintf(PORT1, "Flash Setting done.\r\n");
.................... 
....................    fprintf(PORT1, "Status Register Flash1G Starting...\r\n");
....................    status_register_flash1g();
....................    fprintf(PORT1, "Status Register Flash1G done.\r\n");
.................... 
....................    fprintf(PORT1, "Read ID Flash1G Starting...\r\n");
....................    read_id_flash1g();
....................    fprintf(PORT1, "Read ID Flash1G done.\r\n");
.................... 
....................    fprintf(PORT1, "Sector Erase Flash1G Starting...\r\n");
....................    // гӮўгғүгғ¬гӮ№ 0x0000 гӮ’еҗ«гӮҖгӮ»гӮҜгӮҝгӮ’ж¶ҲеҺ»
....................    sector_erase_flash1g(0x0000);
....................    fprintf(PORT1, "Sector Erase Flash1G done.\r\n");
.................... 
....................    fprintf(PORT1, "Write Data Flash1G Starting...\r\n");
.................... 
....................    // ж–Үеӯ—еҲ—гҒ®жӣёгҒҚиҫјгҒҝ
....................    fprintf(PORT1, "Writing String: %s (Length: %u)\r\n", write_str, data_len);
....................    // (гӮўгғүгғ¬гӮ№, й•·гҒ•, гғҮгғјгӮҝгғқгӮӨгғігӮҝ)
....................    write_data_bytes_flash1g(0x0000, data_len, (int8*)write_str);
.................... 
....................    fprintf(PORT1, "Write Data Flash1G done.\r\n");
.................... 
....................    fprintf(PORT1, "Read Data Flash1G Starting...\r\n");
.................... 
....................    // иӘӯгҒҝеҮәгҒ—гғҗгғғгғ•гӮЎгӮ’дёҖж—Ұ0(гғҢгғ«ж–Үеӯ—)гҒ§гӮҜгғӘгӮўгҒ—гҒҰгҒҠгҒҸ
....................    for(i = 0; i < sizeof(read_buf); i++) {
....................       read_buf[i] = 0;
....................    }
.................... 
....................    // гғҮгғјгӮҝгҒ®иӘӯгҒҝеҮәгҒ—
....................    // (гӮўгғүгғ¬гӮ№, й•·гҒ•, гғҮгғјгӮҝж јзҙҚе…ҲгғқгӮӨгғігӮҝ)
....................    read_data_bytes_flash1g(0x0000, data_len, read_buf);
.................... 
....................    // зөҗжһңгҒ®иЎЁзӨә
....................    // %s гҒ§ж–Үеӯ—еҲ—гҒЁгҒ—гҒҰиЎЁзӨә
....................    fprintf(PORT1, "Read Data(String): %s\r\n", read_buf);
.................... 
....................    // 1гғҗгӮӨгғҲгҒҡгҒӨHEXгҒ§иЎЁзӨәгҒ—гҒҰи©ізҙ°зўәиӘҚ
....................    fprintf(PORT1, "Read Data(Hex): ");
....................    for(i = 0; i < data_len; i++) {
....................       fprintf(PORT1, "%02X ", read_buf[i]);
....................    }
....................    fprintf(PORT1, "\r\n");
.................... 
....................    fprintf(PORT1, "Read Data Flash1G done.\r\n");
.................... }
.................... */
.................... 
.................... /*
.................... // гӮӯгғјгғңгғјгғүе…ҘеҠӣгӮ’еҸ—гҒ‘д»ҳгҒ‘ (жӯЈеёё)
.................... void main()
.................... {
....................    // е…ҘеҠӣз”ЁгҒЁиӘӯгҒҝеҮәгҒ—з”ЁгҒ®гғҗгғғгғ•гӮЎ
....................    char write_str[21];
....................    int8 read_buf[21];
.................... 
....................    int8 data_len;
....................    int8 i;
....................    char c;
.................... 
....................    fprintf(PORT1, "==Program Start==\r\n");
.................... 
....................    fprintf(PORT1, "Flash Setting Starting...\r\n");
....................    flash_setting();
....................    fprintf(PORT1, "Flash Setting done.\r\n");
.................... 
....................    fprintf(PORT1, "Status Register Flash1G Starting...\r\n");
....................    status_register_flash1g();
....................    fprintf(PORT1, "Status Register Flash1G done.\r\n");
.................... 
....................    fprintf(PORT1, "Read ID Flash1G Starting...\r\n");
....................    if(read_id_flash1g()) {
....................       fprintf(PORT1, "Flash ID Check OK.\r\n");
....................    } else {
....................       fprintf(PORT1, "Flash ID Check FAILED. (Check Connections)\r\n");
....................    }
....................    fprintf(PORT1, "Read ID Flash1G done.\r\n");
.................... 
....................    // гғЎгӮӨгғігғ«гғјгғ—пјҡдҪ•еәҰгӮӮе…ҘеҠӣвҶ’жӣёгҒҚиҫјгҒҝвҶ’иӘӯгҒҝеҮәгҒ—гӮ’иЎҢгҒҲгӮӢгӮҲгҒҶгҒ«гҒҷгӮӢ
....................    while(TRUE)
....................    {
....................       fprintf(PORT1, "\r\n================================\r\n");
....................       fprintf(PORT1, "Please enter text (max 20 chars) and press ENTER:\r\n> ");
.................... 
....................       // --- ж–Үеӯ—еҲ—е…ҘеҠӣеҮҰзҗҶ (гӮЁгӮігғјгғҗгғғгӮҜд»ҳгҒҚ) ---
....................       data_len = 0;
....................       while(TRUE)
....................       {
....................          c = fgetc(PORT1); // UART1гҒӢгӮү1ж–Үеӯ—еҸ—дҝЎ (гғ–гғӯгғғгӮӯгғігӮ°)
.................... 
....................          if(c == '\r') // EnterгӮӯгғјгҒҢжҠјгҒ•гӮҢгҒҹгӮүзөӮдәҶ
....................          {
....................              break;
....................          }
....................          else if(c == 0x08 || c == 0x7F) // гғҗгғғгӮҜгӮ№гғҡгғјгӮ№гӮӯгғјгҒ®еҮҰзҗҶ
....................          {
....................              if(data_len > 0)
....................              {
....................                  data_len--;
....................                  fputc(0x08, PORT1); // гӮ«гғјгӮҪгғ«гӮ’жҲ»гҒҷ
....................                  fputc(' ', PORT1);  // з©әзҷҪгҒ§ж–Үеӯ—гӮ’ж¶ҲгҒҷ
....................                  fputc(0x08, PORT1); // еҶҚеәҰгӮ«гғјгӮҪгғ«гӮ’жҲ»гҒҷ
....................              }
....................          }
....................          else if(data_len < 20) // йҖҡеёёгҒ®ж–Үеӯ—е…ҘеҠӣ (гғҗгғғгғ•гӮЎдёҠйҷҗгҒҫгҒ§)
....................          {
....................              write_str[data_len] = c;
....................              data_len++;
....................              fputc(c, PORT1); // е…ҘеҠӣгҒ—гҒҹж–Үеӯ—гӮ’з”»йқўгҒ«иЎЁзӨә (гӮЁгӮігғјгғҗгғғгӮҜ)
....................          }
....................       }
.................... 
....................       write_str[data_len] = '\0'; // ж–Үеӯ—еҲ—гҒ®зөӮз«ҜеҮҰзҗҶ
....................       fprintf(PORT1, "\r\n"); // ж”№иЎҢ
.................... 
....................       // дҪ•гӮӮе…ҘеҠӣгҒ•гӮҢгҒӘгҒӢгҒЈгҒҹе ҙеҗҲгҒҜгӮ№гӮӯгғғгғ—
....................       if (data_len == 0) {
....................           fprintf(PORT1, "No text entered. Try again.\r\n");
....................           continue;
....................       }
.................... 
....................       fprintf(PORT1, "Input received: %s (Length: %u)\r\n", write_str, data_len);
.................... 
....................       // --- гӮ»гӮҜгӮҝж¶ҲеҺ» ---
....................       // жӣёгҒҚиҫјгҒҝеүҚгҒ«еҜҫиұЎгӮ»гӮҜгӮҝ(гҒ“гҒ“гҒ§гҒҜ0x0000гӮ’еҗ«гӮҖгӮ»гӮҜгӮҝ)гӮ’ж¶ҲеҺ»гҒҷгӮӢеҝ…иҰҒгҒҢгҒӮгӮҠгҒҫгҒҷ
....................       fprintf(PORT1, "Sector Erase Flash1G (Addr: 0x0000)...\r\n");
....................       sector_erase_flash1g(0x0000);
....................       fprintf(PORT1, "Sector Erase done.\r\n");
.................... 
....................       // --- жӣёгҒҚиҫјгҒҝ ---
....................       fprintf(PORT1, "Writing Data...\r\n");
....................       // (гӮўгғүгғ¬гӮ№, й•·гҒ•, гғҮгғјгӮҝгғқгӮӨгғігӮҝ)
....................       write_data_bytes_flash1g(0x0000, data_len, (int8*)write_str);
....................       fprintf(PORT1, "Write done.\r\n");
.................... 
....................       // --- иӘӯгҒҝеҮәгҒ—жӨңиЁј ---
....................       fprintf(PORT1, "Reading Data...\r\n");
.................... 
....................       // иӘӯгҒҝеҮәгҒ—гғҗгғғгғ•гӮЎгӮ’гӮҜгғӘгӮў
....................       for(i = 0; i < sizeof(read_buf); i++) read_buf[i] = 0;
.................... 
....................       // гғҮгғјгӮҝгҒ®иӘӯгҒҝеҮәгҒ—
....................       read_data_bytes_flash1g(0x0000, data_len, read_buf);
.................... 
....................       // зөҗжһңгҒ®иЎЁзӨә
....................       fprintf(PORT1, "Read Result(String): %s\r\n", read_buf);
.................... 
....................       // и©ізҙ°гҒӘHEXиЎЁзӨә
....................       fprintf(PORT1, "Read Result(Hex): ");
....................       for(i = 0; i < data_len; i++) {
....................          fprintf(PORT1, "%02X ", read_buf[i]);
....................       }
....................       fprintf(PORT1, "\r\n");
.................... 
....................       // дёҖиҮҙзўәиӘҚ
....................       // з°Ўжҳ“зҡ„гҒӘгғҒгӮ§гғғгӮҜпјҲе…Ҳй ӯж–Үеӯ—гҒЁй•·гҒ•гҒҢеҗҲгҒЈгҒҰгҒ„гӮӢгҒӢгҒӘгҒ©пјү
....................       // еҝ…иҰҒгҒ§гҒӮгӮҢгҒ° strcmp гҒӘгҒ©гҒ§еҺіеҜҶгҒ«жҜ”ијғеҸҜиғҪ
....................    }
.................... }
.................... */
.................... 
.................... 
